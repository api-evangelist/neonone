{
  "info": {
    "name": "Neon CRM API v2",
    "description": "Neon One's Neon CRM API v2 - accounts, households, donations, campaigns, memberships, events, custom fields, orders/store, volunteers, and webhooks. Base URL: https://api.neoncrm.com/v2 (Cloud/Sandbox) or https://trial.z2systems.com/v2 (Trial). All requests use HTTP Basic Authentication with the Org ID as username and an API key as password.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{orgId}}", "type": "string" },
      { "key": "password", "value": "{{apiKey}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.neoncrm.com/v2", "type": "string" },
    { "key": "orgId", "value": "", "type": "string" },
    { "key": "apiKey", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Accounts",
      "item": [
        {
          "name": "List accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"] },
            "description": "Retrieves accounts in bulk."
          }
        },
        {
          "name": "Create an account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"individualAccount\": {\n    \"primaryContact\": {\n      \"firstName\": \"Jane\",\n      \"lastName\": \"Doe\",\n      \"email1\": \"jane@example.org\"\n    }\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"] },
            "description": "Creates a new individual or company account."
          }
        },
        {
          "name": "Retrieve an account",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/accounts/:id", "host": ["{{baseUrl}}"], "path": ["accounts", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Retrieves an account by ID."
          }
        },
        {
          "name": "Update an account",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/accounts/:id", "host": ["{{baseUrl}}"], "path": ["accounts", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Updates an account."
          }
        },
        {
          "name": "Search accounts",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"searchFields\": [\n    { \"field\": \"Email\", \"operator\": \"EQUAL\", \"value\": \"jane@example.org\" }\n  ],\n  \"outputFields\": [\"Account ID\", \"First Name\", \"Last Name\", \"Email 1\"]\n}" },
            "url": { "raw": "{{baseUrl}}/accounts/search", "host": ["{{baseUrl}}"], "path": ["accounts", "search"] },
            "description": "Advanced search over accounts. Rate-limited to 1 simultaneous request."
          }
        },
        {
          "name": "List an account's contacts",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/accounts/:id/contacts", "host": ["{{baseUrl}}"], "path": ["accounts", ":id", "contacts"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Lists contacts linked to an organization account."
          }
        },
        {
          "name": "List an account's donations",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/accounts/:id/donations", "host": ["{{baseUrl}}"], "path": ["accounts", ":id", "donations"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Lists donations made by an account."
          }
        },
        {
          "name": "List an account's memberships",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/accounts/:id/memberships", "host": ["{{baseUrl}}"], "path": ["accounts", ":id", "memberships"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Lists memberships held by the account, including isActive and primaryActiveMembership (API v2.11)."
          }
        },
        {
          "name": "Add an address to an account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"\",\n  \"addressLine1\": \"123 Main St\",\n  \"city\": \"Chicago\",\n  \"zipCode\": \"60601\"\n}" },
            "url": { "raw": "{{baseUrl}}/addresses", "host": ["{{baseUrl}}"], "path": ["addresses"] },
            "description": "Creates a new address for an account."
          }
        }
      ]
    },
